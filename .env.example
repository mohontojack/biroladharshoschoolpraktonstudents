# ============================================
# Biral Adarsha High School - Alumni Reunion 2026
# Environment Variables Configuration
# ============================================
# Copy this file to .env.local and fill in the values

# Database (SQLite for local development)
DATABASE_URL="file:./db/custom.db"

# Admin API Key (used to access /admin panel)
# Change this to a secure random string for production
ADMIN_API_KEY="bairs-admin-2026-secret-key"

# Gmail App Password (for email notifications)
# Follow: Google Account → Security → 2-Step Verification → App passwords
# Leave empty to disable email notifications
EMAIL_APP_PASSWORD=""
